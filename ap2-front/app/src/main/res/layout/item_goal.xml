<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Faixa colorida de prioridade na lateral -->
        <View
            android:id="@+id/priorityStrip"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="@color/priority_medium" />

        <!-- Conteúdo do card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Título + badge concluída + % -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvGoalTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Título da meta"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvConcluida"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_badge_concluida"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="✓ Concluída"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvProgresso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="0%"
                    android:textColor="@color/secondary"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            </LinearLayout>

            <!-- Categoria + prazo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivPriority"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="Prioridade"
                    android:src="@drawable/ic_priority_medium" />

                <TextView
                    android:id="@+id/tvGoalCategoria"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="categoria"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/on_surface_variant" />

                <TextView
                    android:id="@+id/tvGoalPrazo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sem prazo"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/on_surface_variant" />

            </LinearLayout>

            <!-- Barra de progresso -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/secondary"
                android:progressBackgroundTint="@color/surface_variant" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
